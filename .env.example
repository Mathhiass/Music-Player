# .env.example — commit this file, never commit .env

# For local development with a standard PostgreSQL instance:
DATABASE_URL="postgresql://postgres:password@localhost:5432/music_player"

# For local development with Prisma's local dev server (run `prisma dev` first):
# DATABASE_URL="prisma+postgres://localhost:51213/?api_key=YOUR_KEY"

# Required for production:
JWT_SECRET="replace-with-a-long-random-string-minimum-32-chars"
STORAGE_BUCKET_URL="https://your-s3-bucket.region.amazonaws.com"
STORAGE_ACCESS_KEY="your-access-key"
STORAGE_SECRET_KEY="your-secret-key"